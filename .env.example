# Copy this file to .env and fill in your values.
# Used by: docker-compose.yml (variable substitution + container env)

# PostgreSQL
POSTGRES_DB=agolive
POSTGRES_USER=agolive
POSTGRES_PASSWORD=replace-me-db-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=replace-me-redis-password

# Realtime (Go 서버) — 로컬 개발 시에만 필요
REDIS_ADDR=localhost:6379

# Internal API 공유 시크릿 (Spring ↔ Go 내부 통신)
INTERNAL_SECRET=replace-me-internal-secret

SPRING_APPLICATION_NAME=agolive-api

# JWT
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-bytes

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@example.com

# App
APP_BASE_URL=http://localhost
APP_DEFAULT_LOCALE=ko
APP_NAME=agolive
CORS_ALLOWED_ORIGIN=http://localhost
COOKIE_SECURE=false
SWAGGER_ENABLED=false
APP_AUTH_OAUTH_ENABLED=true
APP_SECURITY_PASSWORD_HIBP_ENABLED=true
UNVERIFIED_MEMBER_CLEANUP_ENABLED=true
UNVERIFIED_MEMBER_CLEANUP_AGE_DAYS=7
UNVERIFIED_MEMBER_CLEANUP_CRON=0 0 3 * * *

# OAuth (optional)
GOOGLE_CLIENT_ID=REPLACE_ME
GOOGLE_CLIENT_SECRET=REPLACE_ME
NAVER_CLIENT_ID=REPLACE_ME
NAVER_CLIENT_SECRET=REPLACE_ME
KAKAO_CLIENT_ID=REPLACE_ME
KAKAO_CLIENT_SECRET=REPLACE_ME

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── 프로덕션 전용 (EC2 .env에만 추가) ──────────────────────────
# 도메인
DOMAIN=yourdomain.com
CERTBOT_EMAIL=your-email@example.com

# DB (RDS 엔드포인트)
DB_URL=jdbc:postgresql://<rds-endpoint>:5432/agolive

# ECR
ECR_REGISTRY=<account_id>.dkr.ecr.ap-northeast-2.amazonaws.com
AWS_REGION=ap-northeast-2

# 이미지 태그 (deploy.sh가 자동 갱신)
API_BLUE_TAG=latest
API_GREEN_TAG=latest
REALTIME_BLUE_TAG=latest
REALTIME_GREEN_TAG=latest
FRONTEND_IMAGE_TAG=latest

# 프로덕션 앱 설정
# APP_BASE_URL=https://yourdomain.com
# CORS_ALLOWED_ORIGIN=https://yourdomain.com
# COOKIE_SECURE=true
