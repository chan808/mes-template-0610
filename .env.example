# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=agolive
POSTGRES_USER=agolive
POSTGRES_PASSWORD=

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=                  # 최소 32자 이상 랜덤 문자열
JWT_EXPIRATION=3600000       # ms 단위 (기본 1시간)

# ── Internal 서비스 간 인증 ───────────────────────────────────
INTERNAL_SECRET=             # realtime ↔ api 내부 통신 시크릿

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGIN=http://localhost:3000  # api + realtime 공용. 프로덕션: https://yourdomain.com

# ── Spring (로컬 개발 시 재정의) ──────────────────────────────
# DB_URL: docker-compose.yml에서 컨테이너 호스트명으로 자동 주입
# REDIS_HOST: docker-compose.yml에서 자동 주입

# ── 모니터링 (observability profile) ─────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ── 운영 전용 (로컬 개발 시 불필요) ──────────────────────────
# ECR_REGISTRY=<account_id>.dkr.ecr.ap-northeast-2.amazonaws.com
# AWS_REGION=ap-northeast-2
# API_BLUE_TAG=latest
# API_GREEN_TAG=latest
# REALTIME_BLUE_TAG=latest
# REALTIME_GREEN_TAG=latest
# FRONTEND_IMAGE_TAG=latest
# DOMAIN=yourdomain.com
# CERTBOT_EMAIL=your@email.com
